# ============================================================
# 走云智能排菜系统 — 环境变量配置模板
#
# 使用方法：
#   1. 复制本文件为 .env      →  cp .env.example .env
#   2. 填入您自己的 API Key    →  修改 LLM_API_KEY
#   3. 启动后端服务             →  python -m uvicorn app.main:app --reload
# ============================================================

# === 大模型 API 配置 ===
# 通义千问 API 地址（默认值无需修改，除非使用其他兼容 OpenAI 格式的模型服务）
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ⚠️ 必填：在此填入您的通义千问 API Key
# 申请地址：https://dashscope.console.aliyun.com/
LLM_API_KEY=sk-your-api-key-here

# 模型名称（推荐 qwen-max，也支持 qwen-plus / qwen-turbo）
LLM_MODEL=qwen-max

# === 服务配置 ===
HOST=0.0.0.0
PORT=8000
